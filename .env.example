# Server Configuration
NODE_ENV=development
PORT=5000

# Database (optional for file-based storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/devnest

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars

# Session Configuration (CHANGE IN PRODUCTION!)
SESSION_SECRET=dev-session-secret-change-in-production-min-32-chars

# Security Configuration
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,http://127.0.0.1:5000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
# Log levels: debug, info, warn, error, fatal
# Client-side log level (default: debug in development, warn in production)
VITE_LOG_LEVEL=debug
# Server-side log level (default: debug in development, info in production)
LOG_LEVEL=debug

# Sentry Configuration (Production Monitoring)
# Get your DSN from https://sentry.io
SENTRY_DSN=

# Sentry Configuration for Client (add to .env or use VITE_ prefix)
# VITE_SENTRY_DSN=
