      "status": "implemented",
      "server": {
        "routes": [
          "GET    /api/profile",
          "PUT    /api/profile",
          "POST   /api/profile/upload-picture",
          "PUT    /api/profile/password",
          "DELETE /api/profile",
          "GET    /api/profile/preferences",
          "PUT    /api/profile/preferences"
