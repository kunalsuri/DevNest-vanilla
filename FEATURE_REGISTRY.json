      "id": "auth",
      "name": "Authentication",
      "description": "JWT-based login, registration, token refresh, logout, and session management.",
      "status": "implemented",
      "server": {
        "routes": [
          "POST /api/auth/register",
          "POST /api/auth/login",
          "POST /api/auth/logout",
          "POST /api/auth/logout-all",
          "POST /api/auth/refresh",
          "GET  /api/auth/user"
        ],
        "services": ["server/services/auth-service.ts"],
        "middleware": [
          "server/auth/auth-middleware.ts",
          "server/auth/jwt-utils.ts",
          "server/auth/session-manager.ts"
        ]
      },
      "tests": [
        "tests/unit/server/auth.test.ts",
        "tests/unit/server/jwt-utils.test.ts"
      ],
      "lastUpdated": "2026-04-03"
    },
