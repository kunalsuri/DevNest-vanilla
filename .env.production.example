# DevNest - Production Environment Configuration
# This file contains production-specific environment variable examples
# NEVER commit actual production values to version control

# ===================================
# CRITICAL SECURITY WARNING
# ===================================
# ALL secrets must be changed from defaults before deploying to production!
# Use strong, randomly generated values for all secret keys.
# Generate secure secrets with: openssl rand -base64 32

# ===================================
# Environment
# ===================================
NODE_ENV=production

# ===================================
# Server Configuration
# ===================================
PORT=5000

# ===================================
# Database Configuration (REQUIRED)
# ===================================
# Production database URL (REQUIRED for production)
# Use a managed PostgreSQL service (AWS RDS, Neon, Supabase, etc.)
DATABASE_URL="postgresql://username:password@your-db-host.rds.amazonaws.com:5432/your-production-database"

# ===================================
# JWT Authentication Secrets (CRITICAL)
# ===================================
# CRITICAL: Generate strong random strings (minimum 32 characters)
# These MUST be unique and secure in production
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="CHANGE-THIS-generate-with-openssl-rand-base64-32-minimum-32-chars"
JWT_REFRESH_SECRET="CHANGE-THIS-generate-with-openssl-rand-base64-32-minimum-32-chars"

# ===================================
# Session Security (CRITICAL)
# ===================================
# CRITICAL: Use a cryptographically secure session secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET="CHANGE-THIS-generate-with-openssl-rand-base64-32-minimum-32-chars"

# ===================================
# CORS Configuration (REQUIRED)
# ===================================
# Comma-separated list of allowed origins
# Include your production domain(s) only
ALLOWED_ORIGINS="https://your-production-domain.com,https://www.your-production-domain.com"

# ===================================
# Rate Limiting
# ===================================
# Time window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window (stricter for production)
RATE_LIMIT_MAX_REQUESTS=50

# =============================================================================
# AI SERVICE PROVIDERS (AT LEAST ONE REQUIRED)
# =============================================================================

# Primary AI service (recommended: Gemini for cost-effectiveness)
GEMINI_API_KEY=your-production-gemini-api-key

# Backup AI service (optional but recommended)
OPENAI_API_KEY=sk-your-production-openai-api-key

# =============================================================================
# OLLAMA CONFIGURATION (OPTIONAL)
# =============================================================================

# Production Ollama server (if using local AI)
OLLAMA_BASE_URL=https://your-ollama-server.com
OLLAMA_MODEL=llama3.2

# =============================================================================
# IMAGE SERVICE PROVIDERS (OPTIONAL)
# =============================================================================

PEXELS_API_KEY=your-production-pexels-api-key
PIXABAY_API_KEY=your-production-pixabay-api-key

# =============================================================================
# VIDEO SERVICE PROVIDERS (OPTIONAL)
# =============================================================================

YOUTUBE_API_KEY=your-production-youtube-api-key

# =============================================================================
# SOCIAL MEDIA INTEGRATION (REQUIRED FOR SOCIAL FEATURES)
# =============================================================================

INSTAGRAM_CLIENT_ID=your-production-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-production-instagram-client-secret
REDIRECT_URI=https://your-domain.com/auth/instagram/callback

FACEBOOK_API_VERSION=v18.0

# =============================================================================
# URL CONFIGURATION (PRODUCTION URLS)
# =============================================================================

FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com

# =============================================================================
# ADMIN CONFIGURATION (DO NOT SET IN PRODUCTION)
# =============================================================================

# DO NOT SET THESE IN PRODUCTION - SECURITY RISK
# DEFAULT_ADMIN_USERNAME=
# DEFAULT_ADMIN_PASSWORD=
# DEFAULT_ADMIN_EMAIL=

# =============================================================================
# CLIENT-SIDE CONFIGURATION (PRODUCTION)
# =============================================================================

VITE_API_BASE_URL=https://api.your-domain.com
VITE_APP_NAME=Your Production App Name
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

# Production feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false

# Production settings (disabled)
VITE_DEV_TOOLS=false
VITE_HOT_RELOAD=false

# Production monitoring
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================

# ✅ Required for production:
# □ NODE_ENV=production
# □ Strong SESSION_SECRET (64+ characters)
# □ Valid DATABASE_URL
# □ At least one AI service API key
# □ HTTPS URLs only
# □ No DEFAULT_ADMIN_* variables
# □ Proper CORS configuration
# □ Security headers enabled
# □ SSL/TLS certificates configured
# □ Regular security updates
# □ Monitoring and alerting setup
# □ Backup and disaster recovery plan
# □ Rate limiting configured
# □ Input validation enabled
# □ Error logging without sensitive data
# □ API key rotation schedule
