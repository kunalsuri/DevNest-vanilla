# DevNest Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===================================
# Environment
# ===================================
NODE_ENV=development

# ===================================
# Server Configuration
# ===================================
# Port for the development server (default: 5000)
PORT=5000

# ===================================
# Database Configuration
# ===================================
# Replace with your actual PostgreSQL database URL
# Optional for development (uses file-based storage if not set)
DATABASE_URL="postgresql://username:password@localhost:5432/devnest_db"

# ===================================
# JWT Authentication Secrets
# ===================================
# IMPORTANT: Generate strong random strings for production
# Minimum 32 characters required for security
# Use: openssl rand -base64 32
JWT_ACCESS_SECRET="your-secure-jwt-access-secret-min-32-chars-change-in-production"
JWT_REFRESH_SECRET="your-secure-jwt-refresh-secret-min-32-chars-change-in-production"

# ===================================
# Session Security
# ===================================
# Generate a secure random string for production (minimum 32 characters)
SESSION_SECRET="your-secure-session-secret-key-min-32-chars-change-in-production"

# ===================================
# CORS Configuration
# ===================================
# Comma-separated list of allowed origins
# For development, include your local dev server
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5000"

# ===================================
# Rate Limiting
# ===================================
# Time window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# Optional: Replit Configuration
# ===================================
# Only needed if deploying on Replit
# REPL_ID=your-repl-id-here
