# DevNest Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
# Replace with your actual PostgreSQL database URL
DATABASE_URL="postgresql://username:password@localhost:5432/devnest_db"

# Session Security
# Generate a secure random string for production
SESSION_SECRET="your-secure-session-secret-key-here"

# Server Configuration
# Port for the development server (default: 5000)
PORT=5000

# Environment
NODE_ENV=development

# Optional: Replit Configuration (if deploying on Replit)
# REPL_ID=your-repl-id-here
