  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "vite build && node scripts/build-server.js",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "create-admin": "tsx scripts/create-admin-user.ts",
    "seed-users": "tsx scripts/seed-sncf-users.ts",
    "backup": "tsx scripts/backup-data.ts",
    "restore": "tsx scripts/restore-data.ts",
    "test": "vitest run && npm run test:report",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage && npm run test:report",
    "test:report": "tsx scripts/generate-test-report.ts",
    "test:ci": "npm run check && vitest run && npm run test:report",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\"",
    "validate": "npm run check && npm run lint && npm run test:ci",
    "prepare": "husky"
  },
