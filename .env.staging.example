# DevNest - Staging Environment Configuration
# Values here are safe staging defaults.
# Replace all CHANGE-THIS values before deploying.

# ===================================
# Environment
# ===================================
NODE_ENV=production
PORT=5000

# ===================================
# Database Configuration (optional for file-based mode)
# ===================================
# DATABASE_URL="postgresql://username:password@staging-db-host:5432/devnest_staging"

# ===================================
# JWT Authentication Secrets
# ===================================
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="CHANGE-THIS-staging-access-secret-minimum-32-chars"
JWT_REFRESH_SECRET="CHANGE-THIS-staging-refresh-secret-minimum-32-chars"

# ===================================
# Session Security
# ===================================
SESSION_SECRET="CHANGE-THIS-staging-session-secret-minimum-32-chars"

# ===================================
# CORS
# ===================================
ALLOWED_ORIGINS="https://staging.your-domain.com"

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ===================================
# Logging
# ===================================
LOG_LEVEL=info
VITE_LOG_LEVEL=warn

# ===================================
# Sentry (optional — use a staging project DSN)
# ===================================
SENTRY_DSN=
VITE_SENTRY_DSN=
